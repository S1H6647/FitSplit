<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.FitSplit" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.FitSplit.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.FitSplit</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
    </style>
</resources>